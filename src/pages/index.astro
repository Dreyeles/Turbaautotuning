---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<BaseLayout title="Turba Autotuning | Importadora y Especialistas Multimedia" description="Expertos en instalación y venta de pantallas multimedia para vehículos, sistemas de sonido premium, cámaras de retroceso y seguridad GPS.">
    
    <!-- Banner Principal -->
    <section class="homepage" id="banner">
        <div class="contenido-banner flex">
            <h3><span>TURBA AUTOTUNING:</span>IMPORTADORA<br>CONSOLAS Y MÁS</h3>
            <a href="https://wa.me/51999999999?text=Hola%20Turba%20Autotuning,%20me%20gustar%C3%ADa%20hacer%20una%20consulta" target="_blank" class="boton-contact" rel="noopener noreferrer">Contáctanos</a>
        </div>
    </section>

    <!-- Cuerpo principal con rejilla de Bootstrap corregida -->
    <main class="container py-5">
        
        <!-- Sección Nosotros (Resumen) -->
        <section class="row py-5 align-items-center border-bottom border-secondary" id="nosotros">
            <div class="col-md-7 mb-4 mb-md-0">
                <h2 class="display-4 fw-bold">Nosotros <span class="fs-4 text-muted d-block mt-2">Expertos en pantallas multimedia y sonido vehicular</span></h2>
                <p class="fs-5 text-secondary mt-3">
                    En <strong>Turba Autotuning</strong>, somos un equipo apasionado de expertos en tecnología y diseño dedicados a transformar la experiencia dentro de tu vehículo. Nuestra misión es ofrecerte las mejores soluciones multimedia, desde pantallas personalizadas hasta sistemas de sonido premium. Te ayudamos a llevar la conectividad y el entretenimiento a otro nivel.
                </p>
                <p class="fs-6 text-secondary">
                    ¡Gracias por confiar en nosotros para mejorar tu conducción! 🌟
                </p>
            </div>
            <div class="col-md-5">
                <div class="ratio ratio-16x9 rounded overflow-hidden shadow-lg border border-secondary">
                    <iframe src="https://www.youtube.com/embed/uGYSVuG6KeY?autoplay=0" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                </div>
            </div>
        </section>

        <!-- Galería Carrusel de Trabajos Recientes -->
        <section class="my-5 py-4">
            <div class="section-header">
                <h2>Trabajos Destacados</h2>
            </div>
            <div id="carouselExampleSlidesOnly" class="carousel slide rounded-4 overflow-hidden shadow-lg border border-secondary" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active" data-bs-interval="2500">
                        <img src={`${import.meta.env.BASE_URL}imagenes/c1.jpg`} class="d-block w-100 carousel-img" alt="Instalación de consola multimedia Turba">
                    </div>
                    <div class="carousel-item" data-bs-interval="2500">
                        <img src={`${import.meta.env.BASE_URL}imagenes/c2.jpg`} class="d-block w-100 carousel-img" alt="Pantalla IPS instalada en vehículo">
                    </div>
                    <div class="carousel-item" data-bs-interval="2500">
                        <img src={`${import.meta.env.BASE_URL}imagenes/c3.jpg`} class="d-block w-100 carousel-img" alt="Consola tuning a medida">
                    </div>
                    <div class="carousel-item" data-bs-interval="2500">
                        <img src={`${import.meta.env.BASE_URL}imagenes/c4.jpg`} class="d-block w-100 carousel-img" alt="Equipo de sonido vehicular premium">
                    </div>
                    <div class="carousel-item" data-bs-interval="2500">
                        <img src={`${import.meta.env.BASE_URL}imagenes/c5.jpg`} class="d-block w-100 carousel-img" alt="Cámara de retroceso instalada">
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección de Categorías de Productos -->
        <section class="product" id="productos">
            <div class="section-header">
                <h2>Últimos días de oferta</h2>
            </div>
            <div class="row">
                <!-- Se utilizan las rutas limpias correctas y se corrigen los textos -->
                <ProductCard 
                    title="Cámaras de Retroceso" 
                    image="/imagenes/CAMARAS DE RETOCESO.jpeg" 
                    link="/camaras" 
                    buttonText="Ver Catálogo" 
                    description="Asistencia de estacionamiento HD con visión nocturna."
                />
                <ProductCard 
                    title="Pantallas Multimedia" 
                    image="/imagenes/PANTALLA IPS.webp" 
                    link="/pantallas" 
                    buttonText="Ver Catálogo" 
                    description="Pantallas IPS de alta definición con Android Auto y CarPlay."
                />
                <ProductCard 
                    title="Equipos de Sonido" 
                    image="/imagenes/equipodesonido.jpg" 
                    link="/equipo" 
                    buttonText="Ver Catálogo" 
                    description="Sonido de alta definición, componentes, amplificadores y subwoofers."
                />
                <ProductCard 
                    title="Sistemas GPS y Alarmas" 
                    image="/imagenes/GPS.jpeg" 
                    link="/gps" 
                    buttonText="Ver Catálogo" 
                    description="Seguridad activa, rastreo satelital y alarmas anti-asalto."
                />
            </div>
        </section>

        <!-- Ventajas Competitivas -->
        <section class="section-icons">
            <div class="row text-center px-3">
                <div class="col-12 col-md-4 box-icons mb-4 mb-md-0">
                    <i class="bi bi-airplane-fill mb-3"></i>
                    <h3>Envío a Todo el País</h3>
                    <p class="text-secondary">Enviamos tus componentes de tuning y pantallas de forma rápida y segura a nivel nacional, con un embalaje garantizado.</p>
                </div>
                <div class="col-12 col-md-4 box-icons mb-4 mb-md-0">
                    <i class="bi bi-gift-fill mb-3"></i>
                    <h3>Regalos por Compra</h3>
                    <p class="text-secondary">Por la compra e instalación de tu pantalla multimedia, te obsequiamos la cámara de retroceso o accesorios adicionales.</p>
                </div>
                <div class="col-12 col-md-4 box-icons">
                    <i class="bi bi-shield-check mb-3"></i>
                    <h3>Garantía de Reembolso</h3>
                    <p class="text-secondary">Todos nuestros servicios de instalación y repuestos cuentan con garantía total por desperfectos de fábrica.</p>
                </div>
            </div>
        </section>

        <!-- Ubícanos -->
        <section class="py-5" id="ubicanos">
            <div class="section-header">
                <h2>Ubícanos</h2>
            </div>
            <!-- Mapa interactivo en contenedor fluido y responsivo -->
            <div class="map-container rounded-4 overflow-hidden shadow">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d410.2385292760834!2d-77.0779303276591!3d-11.983591304617695!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105cf0021d3a5f5%3A0xe77558e41b6e2a23!2sMec%C3%A1nica%20Electr%C3%B3nica%20AUTOMOTRIZ!5e0!3m2!1ses-419!2spe!4v1722828182272!5m2!1ses-419!2spe"
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Ubicación de Turba Autotuning">
                </iframe>
            </div>
        </section>

        <!-- Formulario de Contacto (Web3Forms) -->
        <section class="py-4" id="contactanos">
            <div class="container-contact shadow-lg">
                <h2>Contáctanos</h2>
                <form action="https://api.web3forms.com/submit" method="POST">
                    <!-- Clave pública de Web3Forms. El usuario puede cambiarla para que le lleguen a su correo -->
                    <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
                    <input type="hidden" name="subject" value="Nuevo Mensaje de Contacto - Turba Autotuning" />
                    <input type="checkbox" name="botcheck" class="d-none" />

                    <div class="form-group">
                        <label for="nombre">Nombre Completo:</label>
                        <input type="text" id="nombre" name="nombre" placeholder="Ingresa tu nombre" required />
                    </div>
                    <div class="form-group">
                        <label for="email">Correo Electrónico:</label>
                        <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" required />
                    </div>
                    <div class="form-group">
                        <label for="asunto">Asunto de consulta:</label>
                        <input type="text" id="asunto" name="asunto" placeholder="Ej. Cotización de Pantalla para Toyota" required />
                    </div>
                    <div class="form-group">
                        <label for="mensaje">Mensaje:</label>
                        <textarea id="mensaje" name="mensaje" placeholder="Describe brevemente lo que necesitas..." required></textarea>
                    </div>
                    
                    <button type="submit" class="btn-submit">Enviar Mensaje</button>
                </form>
            </div>
        </section>

    </main>
</BaseLayout>
