---
interface Props {
  title: string;
  image: string;
  link?: string;
  buttonText?: string;
  description?: string;
}

const { 
  title, 
  image, 
  link = "https://wa.me/51999999999?text=Hola%20Turba%20Autotuning,%20estoy%20interesado%20en:%20" + encodeURIComponent(title), 
  buttonText = "Saber más",
  description = ""
} = Astro.props;
---

<div class="col-12 col-md-6 col-lg-3 mb-4">
    <div class="card bg-light shadow-sm border-0 px-2 py-3 h-100 d-flex flex-column justify-content-between">
        <div class="text-center image-container">
            <img src={image} alt={title} loading="lazy" class="img-fluid rounded" />
        </div>
        <div class="card-body d-flex flex-column justify-content-between flex-grow-1">
            <div>
                <h5 class="card-title text-center">{title}</h5>
                {description && <p class="card-text text-center text-muted">{description}</p>}
            </div>
            <div class="mt-3">
                <a href={link} class="btn btn-primary w-100">{buttonText}</a>
            </div>
        </div>
    </div>
</div>

<style>
    .image-container {
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 12px;
        background-color: rgba(255, 255, 255, 0.02);
    }
    
    .card img {
        max-height: 100%;
        width: auto;
        object-fit: contain;
        transition: transform 0.3s ease;
    }
    
    .card:hover img {
        transform: scale(1.08);
    }
</style>
